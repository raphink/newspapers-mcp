{
  "name": "newspapers-mcp",
  "version": "1.0.0",
  "description": "MCP server for searching online newspaper archives across multiple countries and regions",
  "type": "module",
  "bin": {
    "newspapers-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
